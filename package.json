{
  "name": "visual-foxpro-compiler",
  "displayName": "Visual Foxpro PR2 compiler",
  "description": "Ao salvar um .pr2: gera o .prg com o mesmo nome (UTF-8 para Windows-1252, se ativado) e compila para .FXP.",
  "version": "1.0.19",
  "publisher": "vfcompiler",
  "author": "Marco Plaza",
  "icon": "images/nfoxLogo.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "os": [
    "win32"
  ],
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:foxpro"
  ],
  "contributes": {
  "configuration": {
    "title": "Visual FoxPro Compiler",
    "properties": {
      "visualFoxproCompiler.convertEncodingBeforeCompile": {
        "type": "boolean",
        "default": true,
        "description": "Ao salvar .pr2: converter UTF-8 para Windows-1252 no .prg gerado. Se desativado, copia os bytes sem alterar."
      }
    }
  },
  "languages": [
      {
        "id": "foxpro",
        "extensions": [
          ".prg",
          ".pr2"
        ],
        "aliases": [
          "Visual FoxPro",
          "FoxPro"
        ],
        "configuration": "./language-configuration.json"
      }
    ]
  },
  "homepage": "https://github.com/nfoxdev",
  "repository": {
    "type": "git",
    "url": "https://github.com/nfoxdev/visual-foxpro-compiler.git"
  },
  "main": "./out/extension.js",
  "keywords": [
    "foxpro",
    "vfp",
    "compiler"
  ],
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test",
    "vsix": "npm run compile && vsce package"
  },
  "dependencies": {
    "iconv-lite": "^0.6.3"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/mocha": "^10.0.8",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.11.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.5",
    "@vscode/test-cli": "^0.0.9",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.2.2"
  }
}